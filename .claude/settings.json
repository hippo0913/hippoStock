{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(git*)",
      "Bash(pytest*)",
      "Bash(ruff*)",
      "Bash(uvicorn*)"
    ],
    "deny": [
      "Read(_config/cfg.json)",
      "Edit(_config/cfg.json)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto_lint.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '提示：session 结束，记得运行 /checkpoint 保存进度' >&2",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
